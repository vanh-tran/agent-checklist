#!/usr/bin/env bash
# SessionStart hook for agent-checklist plugin
# Ensures the server is running so the MCP endpoint is available.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Try to start the server if it's not already running.
# First check if `agent-checklist` is on PATH (global install).
# Otherwise, fall back to running from the plugin's dist/ directly.
if command -v agent-checklist &>/dev/null; then
  agent-checklist ensure-running 2>/dev/null || true
elif [ -x "${PLUGIN_ROOT}/dist/server/index.js" ]; then
  node "${PLUGIN_ROOT}/dist/server/index.js" ensure-running 2>/dev/null || true
fi

# Emit empty JSON — no additional context needed.
# The SKILL.md and .mcp.json handle everything else.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{}\n'
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{}\n'
else
  printf '{}\n'
fi

exit 0
