#!/usr/bin/env bash
# SessionStart hook for agent-checklist plugin
# Builds on first use (if needed), then ensures the server is running.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ERROR_LOG="/tmp/agent-checklist-error.log"

# Claude passes hook data via stdin as JSON (not env vars). Read it first.
# Write session_id keyed by $PPID (Claude's PID) so concurrent sessions in the
# same project don't overwrite each other — each session has a unique parent PID.
SESSION_JSON="$(cat)"
SESSION_ID="$(echo "$SESSION_JSON" | node -e \
  "const d=JSON.parse(require('fs').readFileSync(0,'utf8'));process.stdout.write(d.session_id||d.sessionId||'')" \
  2>/dev/null || true)"
if [ -n "$SESSION_ID" ]; then
  mkdir -p /tmp/agent-checklist-sessions
  echo "$SESSION_ID" > "/tmp/agent-checklist-sessions/$PPID"
fi

# Build from source if dist/ doesn't exist yet (first use after plugin install).
if [ ! -f "${PLUGIN_ROOT}/dist/server/index.js" ]; then
  cd "${PLUGIN_ROOT}"
  if command -v pnpm &>/dev/null; then
    pnpm install --frozen-lockfile 2>>"$ERROR_LOG" && pnpm build 2>>"$ERROR_LOG"
  elif command -v npm &>/dev/null; then
    npm ci 2>>"$ERROR_LOG" && npm run build 2>>"$ERROR_LOG"
  fi
fi

# Issue 2: Prefer the plugin-local binary (always present after install),
# fall back to a global install, then the bare node invocation.
PLUGIN_BIN="${PLUGIN_ROOT}/node_modules/.bin/agent-checklist"

if [ -x "$PLUGIN_BIN" ]; then
  START_CMD="$PLUGIN_BIN"
elif command -v agent-checklist &>/dev/null; then
  START_CMD="agent-checklist"
elif [ -f "${PLUGIN_ROOT}/dist/server/index.js" ]; then
  START_CMD="node ${PLUGIN_ROOT}/dist/server/index.js"
else
  printf '{"error":"agent-checklist: dist/server/index.js not found. Run: pnpm build inside %s"}\n' "$PLUGIN_ROOT"
  exit 1
fi

# Issue 3: Surface failures as a JSON error instead of silently swallowing them.
if ! $START_CMD ensure-running 2>>"$ERROR_LOG"; then
  printf '{"error":"agent-checklist server failed to start. Check %s for details."}\n' "$ERROR_LOG"
  cat "$ERROR_LOG" >&2
  exit 1
fi

# Self-register the MCP server in ~/.claude/settings.json.
#
# We point to a STABLE launcher script at a fixed path rather than to the
# version-specific binary. The launcher reads installed_plugins.json at
# runtime to find the current version, so settings.json never needs updating
# after a plugin upgrade — the first session after any update just works.
#
# We also write the launcher script itself here, so it stays current even if
# the user moves their plugins directory.
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
LAUNCHER_DIR="$HOME/.claude/plugins/data/agent-checklist"
LAUNCHER="$LAUNCHER_DIR/mcp-launcher.sh"

# Write/refresh the launcher script.
mkdir -p "$LAUNCHER_DIR"
cat > "$LAUNCHER" << 'LAUNCHER_EOF'
#!/usr/bin/env bash
# Stable MCP launcher for agent-checklist.
# Dynamically resolves the currently-installed plugin version at runtime.
set -euo pipefail
INSTALLED_JSON="$HOME/.claude/plugins/installed_plugins.json"
if [ ! -f "$INSTALLED_JSON" ]; then
  echo "agent-checklist: installed_plugins.json not found" >&2; exit 1
fi
INSTALL_PATH="$(node -e "
  const d = JSON.parse(require('fs').readFileSync('$INSTALLED_JSON', 'utf8'));
  const p = d.plugins && d.plugins['agent-checklist@agent-checklist'];
  if (!p || !p[0]) { process.stderr.write('agent-checklist: not in installed_plugins.json\n'); process.exit(1); }
  process.stdout.write(p[0].installPath);
")"
SERVER_BIN="${INSTALL_PATH}/dist/server/index.js"
if [ ! -f "$SERVER_BIN" ]; then
  echo "agent-checklist: binary not found at $SERVER_BIN" >&2; exit 1
fi
exec node "$SERVER_BIN" mcp-stdio
LAUNCHER_EOF
chmod +x "$LAUNCHER"

if [ -f "$CLAUDE_SETTINGS" ]; then
  node -e "
    const fs = require('fs');
    const settingsPath = '$CLAUDE_SETTINGS';
    const launcher    = '$LAUNCHER';
    try {
      const s = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
      s.mcpServers = s.mcpServers || {};
      const existing = s.mcpServers['checklist'];
      const wantCmd  = { command: '/bin/bash', args: [launcher] };
      // Write only when missing, still url-style, or pointing at a versioned
      // path (migrate users who have the old command-style registration).
      const isVersioned = existing?.args?.[0]?.includes('/cache/agent-checklist/');
      if (!existing || existing.url || isVersioned) {
        s.mcpServers['checklist'] = wantCmd;
        fs.writeFileSync(settingsPath, JSON.stringify(s, null, 2) + '\n');
      }
    } catch (e) { /* settings unreadable — skip silently */ }
  " 2>>"$ERROR_LOG" || true
fi

# Emit empty JSON — no additional context needed.
printf '{}\n'
exit 0
